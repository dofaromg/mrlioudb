#!/bin/bash
# Pre-commit hook for Merkle tree signature verification
# This hook ensures that Merkle signatures are updated before commits

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running Merkle signature pre-commit hook...${NC}"

# Check if merkle-sign.sh exists
if [[ ! -x "./merkle-sign.sh" ]]; then
    echo -e "${RED}Error: merkle-sign.sh not found or not executable${NC}"
    echo -e "${YELLOW}Please ensure merkle-sign.sh is in the repository root${NC}"
    exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
    echo -e "${GREEN}No files staged for commit${NC}"
    exit 0
fi

echo -e "${YELLOW}Updating Merkle tree signature...${NC}"

# Run merkle-sign.sh in incremental mode
if ./merkle-sign.sh incremental; then
    echo -e "${GREEN}✓ Merkle signature updated successfully${NC}"
    
    # Check if .merkle directory exists and stage metadata files
    if [[ -d ".merkle" ]]; then
        # Only stage root and metadata files, not the full tree
        if [[ -f ".merkle/root.txt" ]]; then
            git add .merkle/root.txt 2>/dev/null || true
        fi
        if [[ -f ".merkle/metadata.json" ]]; then
            git add .merkle/metadata.json 2>/dev/null || true
        fi
        echo -e "${GREEN}✓ Merkle metadata staged for commit${NC}"
    fi
    
    exit 0
else
    echo -e "${RED}✗ Failed to update Merkle signature${NC}"
    echo -e "${YELLOW}Please fix the errors and try again${NC}"
    exit 1
fi
