# FlowAgent 環境變數配置範例 / Environment Variables Configuration Example
# 
# 使用說明 / Instructions:
# 1. 複製此檔案為 .env / Copy this file to .env
#    cp .env.example .env
#
# 2. 使用密碼生成工具 / Use password generation tool
#    bash scripts/generate_password.sh --apply
#
# 3. 或手動設置安全密碼 / Or manually set a secure password
#    使用強隨機密碼（至少 32 字元）/ Use strong random password (at least 32 characters)
#
# ⚠️  重要：.env 檔案不會被提交到 Git / IMPORTANT: .env file will not be committed to Git

# ============================================================================
# MongoDB 配置 / MongoDB Configuration
# ============================================================================

# MongoDB 密碼（必須更改！）/ MongoDB Password (MUST CHANGE!)
# 請使用 scripts/generate_password.sh 生成安全密碼
# Use scripts/generate_password.sh to generate a secure password
MONGODB_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# MongoDB 連接 URI / MongoDB Connection URI
# 將在 docker-compose 中自動使用上面的密碼
# Will automatically use the password above in docker-compose
MONGODB_URI=mongodb://admin:${MONGODB_PASSWORD}@mongodb:27017

# ============================================================================
# Next.js Frontend 配置 / Next.js Frontend Configuration
# ============================================================================

# GrowthBook API 配置 / GrowthBook API Configuration
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=YOUR_GROWTHBOOK_CLIENT_KEY_HERE

# Node 環境 / Node Environment
NODE_ENV=production

# ============================================================================
# GCP 配置 / GCP Configuration
# ============================================================================

# GCP 專案 ID / GCP Project ID
PROJECT_ID=flowmemorysync

# GCP 區域 / GCP Region
REGION=asia-east1

# GCP 可用區 / GCP Zone
ZONE=asia-east1-a

# GKE 叢集名稱 / GKE Cluster Name
CLUSTER_NAME=modular-cluster

# ============================================================================
# 安全提醒 / Security Reminders
# ============================================================================
#
# ✅ 使用強隨機密碼（至少 32 字元）/ Use strong random passwords (at least 32 characters)
# ✅ 不要將 .env 檔案提交到 Git / Do not commit .env file to Git
# ✅ 生產環境使用 Secret Manager / Use Secret Manager for production
# ✅ 定期輪換密碼 / Rotate passwords regularly
# ✅ 限制對 .env 檔案的訪問權限 / Restrict access to .env file
#
# 生產環境最佳實踐 / Production Best Practices:
# - Google Secret Manager: https://cloud.google.com/secret-manager
# - Kubernetes Secrets: kubectl create secret
# - External Secrets Operator: https://external-secrets.io/
#
