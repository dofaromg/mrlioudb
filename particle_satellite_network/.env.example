# Particle Satellite Network Environment Variables

# System Configuration
SYSTEM_MODE=development
LOG_LEVEL=INFO

# Satellite Layer Configuration
GEO_ALTITUDE=35786
MEO_ALTITUDE=10000
LEO_ALTITUDE=1000

# Network Configuration
MESH_TOPOLOGY_ENABLED=true
INTER_SATELLITE_LINKS_ENABLED=true
DYNAMIC_ROUTING_ENABLED=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
WEBSOCKET_PORT=8001

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=particle_satellite_network
REDIS_URI=redis://localhost:6379

# CI/CD Integration
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
CICD_SIGNAL_PROCESSING_ENABLED=true

# Visualization
VISUALIZATION_PORT=5173
CESIUM_ION_ACCESS_TOKEN=your_cesium_token_here

# Experiments (Private)
EXPERIMENTS_DATA_PATH=./experiments/data
EXPERIMENTS_RESULTS_PATH=./experiments/results
EXPERIMENT_MODE=private

# Google Earth Integration
GOOGLE_EARTH_ENABLED=true
TERRAIN_PROVIDER=cesium_world_terrain

# Security
SECRET_KEY=your_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
